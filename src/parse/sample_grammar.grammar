$namespace sample
$class_name parser
$header_guard SAMPLE_PARSER_HPP

$token Constant double
$nterm expression double
$nterm term double
$nterm factor double

$grammar

expression =
    expression "+" term { $1 + $3 }
    | term { $1 } ;
term =
    term "*" factor { $1 * $3 }
    | factor { $1 } ;
factor =
    "(" expression ")" { $2 }
    | Constant { $1 } ;
